# --- Groq (LLM: contextual headers at ingest + answer generation at query time) ---
# Free key: https://console.groq.com/keys
GROQ_API_KEY=

# --- Supabase (vector + full-text store) ---
# Project URL + keys: https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
# anon key is used by the app (read via RPC, RLS-protected)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key is used ONLY by scripts/upload.ts (server-side, never shipped to client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Models (override-able; defaults are free tiers) ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- Hugging Face (query embedding on the deployed app; bge-small) ---
# Free token (role: read): https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Optional: rate limiting (Upstash Redis). App no-ops gracefully if unset. ---
# Free DB: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: semantic answer cache (Upstash Vector, 384 dims). No-ops if unset. ---
# Free index (dimension=384, metric=COSINE): https://console.upstash.com/vector
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
